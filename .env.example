# Copy to .env and adjust as needed. Safe defaults for local docker-compose use.

# --- Postgres (one instance, one DB per service) ---
POSTGRES_USER=sctpcrs
POSTGRES_PASSWORD=sctpcrs_dev_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Neo4j ---
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=sctpcrs_dev_password

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# --- Auth / JWT (shared secret across all services — HS256) ---
JWT_SECRET=change_me_dev_only_shared_hs256_secret_please_rotate_in_real_deploys
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=7
MFA_SECRET_ENC_KEY=change_me_dev_only_fernet_key_32byte_urlsafe_base64==

# --- Gateway ---
GATEWAY_RATE_LIMIT_PER_MIN=100
GATEWAY_LOGIN_RATE_LIMIT_PER_MIN=5
CORS_ALLOWED_ORIGINS=http://localhost:5173

# --- Service internal URLs (docker-compose DNS names) ---
AUTH_SERVICE_URL=http://auth-service:8000
VENDOR_SERVICE_URL=http://vendor-service:8000
RISK_SERVICE_URL=http://risk-service:8000
SBOM_SERVICE_URL=http://sbom-service:8000
COMPLIANCE_SERVICE_URL=http://compliance-service:8000
MONITORING_SERVICE_URL=http://monitoring-service:8000
INCIDENT_SERVICE_URL=http://incident-service:8000

# --- External adapter modes: mock (default) | real ---
NVD_MODE=mock
KEV_MODE=mock
MISP_MODE=mock
VIRUSTOTAL_MODE=mock
SHODAN_MODE=mock
ABUSEIPDB_MODE=mock
TICKETING_MODE=mock

# Real API keys (only needed if a *_MODE above is set to "real")
NVD_API_KEY=
VIRUSTOTAL_API_KEY=
SHODAN_API_KEY=
MISP_URL=
MISP_API_KEY=
ABUSEIPDB_API_KEY=
JIRA_BASE_URL=
JIRA_API_TOKEN=
SERVICENOW_BASE_URL=
SERVICENOW_API_TOKEN=

# --- Frontend ---
VITE_API_BASE_URL=http://localhost:8080/api

# --- Seeding ---
SEED_VENDOR_COUNT=50
SEED_RANDOM_SEED=42
